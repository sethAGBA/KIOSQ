{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["ES2022"],
    "module": "commonjs",
    "ignoreDeprecations": "6.0",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "outDir": ".vercel/output/functions",
    "rootDir": ".",
    "paths": {}
  },
  "include": ["api/**/*.ts", "db/**/*.ts"],
  "exclude": ["node_modules", "dist", "src"]
}
